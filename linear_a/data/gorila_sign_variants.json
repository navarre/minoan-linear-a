      "notes": "Optional observations about the sign"
    },
    "conventions": {
      "parenthesized_refs": "References in parentheses (e.g., '(KH 5.2)') indicate uncertain or doubtful attributions",
      "sub_variants": "Some signs have sub-variants indicated by letter suffixes: 'f' = female/feminine form, 'm' = male/masculine form, 'a/b/c/d' = distinct sub-types",
      "site_abbreviations": {
        "HT": "Hagia Triada",
        "KH": "Khania (Chania)",
        "ZA": "Zakros",
