{
  "metadata": {
    "title": "GORILA Index des Signes (Sign Index) — Schema, Map, and Batch Plan",
    "source": "Godart & Olivier, GORILA Vol. 5 (1985), Études Crétoises 21, pp. 135-326",
    "source_pages_file": "Vol 5 file pages 187-378",
    "source_pages_printed": "Vol 5 printed pages 135-326",
    "description": "The Index des Signes is the most valuable structured data in GORILA: every attestation of every Linear A sign across the entire corpus, cross-referenced by neighbor context and inscription location. Each page is devoted to one sign (or several rare variants). Rows show the sign in context with its neighbors (as numeric sign references with the target sign underlined), the functional category classifier (rubrique A-J from the intro methodology), and the specific inscription reference (site + inscription number + position).",
    "extraction_date": "2026-04-04",
    "extraction_strategy": "Vision sampling was used to (1) confirm the schema, (2) build the sign-to-file-page map, and (3) extract golden-data examples for AB 01 to serve as ground truth. Full row-by-row extraction of all ~192 pages (estimated 4,000-6,000 rows, many containing handwritten Linear A glyphs in the leftmost column) is delegated to Claude Code's batch OCR pipeline. This file provides the schema and metadata the batch pipeline needs to validate its output.",
    "estimated_total_rows": "4000-6000",
    "confirmed_pages_sampled": [
      194,
      195,
      196,
      198,
      200,
      205,
      210,
      215,
      220,
      230,
      240,
      250,
      260,
      270,
      290,
      300,
      310,
      320,
      330,
      350,
      370,
      378
    ],
    "sign_ranges": {
      "confirmed": 20,
      "inferred": 77,
      "total_entries": 98
    },
    "schema": {
      "row_columns": {
        "1_context_glyphs": "Leftmost column: the target sign shown in context with its Linear A neighbors, drawn as handwritten glyphs. Brackets indicate damaged/reconstructed signs.",
        "2_catalog_number": "Optional: 'A 5xx/6xx/7xx' catalog number for rare sign combinations (appears only for entries at bottom of page).",
        "3_classifier": "Optional single letter (A-J) indicating functional category rubrique from the methodology introduction. 'PHAISTOS' label appears for certain signs tied to specific find contexts.",
        "4_numeric_sequence": "Numeric context sequence showing neighbors as sign numbers (e.g., '08-01-67'). The target sign number is UNDERLINED in the original. Format markers: [ ] = bracket/damaged, ( ) = parenthesized/uncertain, ... = ellipsis/gap, * = starred/noteworthy, ' ' = quoted/alternate reading.",
        "5_inscription_reference": "Rightmost column: specific inscription citation in format 'SITE INSCRIPTION.POSITION' with superscript for line number. Examples: 'HT 6a.6¹', 'PK Za 9.2⁴', 'KH Wa 1001γ³'."
      },
      "classifier_rubriques": {
        "A": "Signes isolés (isolated signs) — base category, with sub-rubriques B-J",
        "B": "Sub-rubrique of A",
        "C": "Sub-rubrique of A",
        "D": "Sub-rubrique of A",
        "E": "Sub-rubrique of A (word-initial?)",
        "F": "Sub-rubrique of A",
        "G": "Sub-rubrique of A (word-medial?)",
        "H": "Sub-rubrique of A (catalog/rare combinations)",
        "J": "Sub-rubrique of A",
        "notes": "Exact semantics of each rubrique are described in the methodology introduction (Vol 5 pages 187-193). Rubriques A-J appear to encode sign position within word/inscription, sign isolation status, and attestation certainty."
      },
      "page_header": "Top of each page shows: the target sign as a Linear A glyph (top-left) and the sign's catalog number in large type (top-right). This header is how the sign-to-page map was built.",
      "page_footer": "Printed page number appears at bottom-left (even pages) or bottom-right (odd pages). Printed pages run 135-326, which corresponds to file pages 187-378 (offset of ~52)."
    },
    "site_abbreviations_reference": "Same as gorila_concordances.json and gorila_sign_variants.json. Key sites: HT=Hagia Triada, KH=Khania, ZA=Zakros, PH=Phaistos, KN=Knossos, ARKH=Arkhanes, IO=Iouktas, PK=Palaikastro, MA=Malia, TY=Tylissos, AP=Apodoulou, SY=Symi, KE=Kea, SI=Sitia, etc."
  },
